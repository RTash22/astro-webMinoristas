---

<section class="relative overflow-hidden pt-16 pb-20 lg:pt-32 lg:pb-32" id="inicio">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col lg:flex-row items-center gap-12">
    <!-- Text -->
    <div class="flex-1 text-center lg:text-left">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black leading-tight tracking-tight text-slate-900 mb-6">
        Financiamos tu <span class="text-primary">inventario hoy</span>, paga después.
      </h1>
      <p class="text-lg text-slate-600 mb-8 max-w-2xl mx-auto lg:mx-0">
        BNPL especializado para el sector retail. Optimiza tu flujo de trabajo con nuestras soluciones
        financieras diseñadas para el crecimiento de tu negocio.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
        <button
          id="btn-cotizacion"
          class="flex items-center justify-center rounded-xl bg-primary px-8 py-4 text-base font-bold text-white shadow-lg hover:shadow-primary/30 transition-all cursor-pointer"
        >
          Solicitar Cotización
        </button>
        <a
          href="#sobre-nosotros"
          class="flex items-center justify-center rounded-xl border border-slate-300 px-8 py-4 text-base font-bold text-slate-700 hover:bg-slate-50 transition-all"
        >
          Saber más
        </a>
      </div>
    </div>

    <!-- Image -->
    <div class="flex-1 w-full max-w-[500px] lg:max-w-none">
      <div class="relative rounded-2xl overflow-hidden shadow-2xl aspect-[4/3] bg-primary/5">
        <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-transparent"></div>
        <img
          alt="Retail inventory management"
          class="w-full h-full object-cover"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuCxgsKg7cSTTOfDnl5PrQetPr7h_mZ7eROqUM7nmPvSiWx-drCS-fPOuoVgehpg_O5irB20yk6GVdOrL9aNXaqmnB6SJmszZu0lANBu4aam9t83gTA1b8sQJIeNi9HGiNZp6ziRj6w30L5NHHlwDtnxZIoNfLY5EhEr_XYj70gxJ4H-f4nFN42-alHEPqYLzm8s8j4mZrzCm_3Vj7ORr5LQG28ewUuPtyCw9Q6yud7cSn6G9zl6bOux_Mr46dyR81v20o2YvFVi8SA"
        />
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById('btn-cotizacion')?.addEventListener('click', () => {
    document.getElementById('modal-login')?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  });
</script>
