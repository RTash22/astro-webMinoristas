---
import AccountBalance from '../icons/AccountBalance.astro';
---

<footer class="bg-slate-900 text-white py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between items-center border-b border-slate-800 pb-8 mb-8 gap-8">
      <!-- Logo -->
      <div class="flex items-center gap-2">
        <AccountBalance class="text-primary size-8" />
        <span class="text-xl font-bold tracking-tight">EMPRESA</span>
      </div>

      <!-- Links legales -->
      <div class="flex flex-wrap justify-center gap-8">
        <a class="text-sm text-slate-400 hover:text-white transition-colors" href="#">Términos y Condiciones</a>
        <a class="text-sm text-slate-400 hover:text-white transition-colors" href="#">Política de Privacidad</a>
        <a class="text-sm text-slate-400 hover:text-white transition-colors" href="#">Cookies</a>
      </div>
    </div>

    <div class="flex flex-col md:flex-row justify-between items-center text-slate-500 text-xs gap-4">
      <p>© 2026 FinRetail Inc. Todos los derechos reservados.</p>
      <p>Página hecha por Grupo Downlabs.</p>
    </div>
  </div>
</footer>
